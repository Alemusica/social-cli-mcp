{
  "mcpServers": {
    "surrealdb": {
      "command": "surrealdb-mcp-server",
      "env": {
        "SURREALDB_URL": "http://localhost:8000",
        "SURREALDB_NS": "social",
        "SURREALDB_DB": "analytics",
        "SURREALDB_USER": "root",
        "SURREALDB_PASS": "root"
      }
    },
    "flutur-ops": {
      "command": "npx",
      "args": ["tsx", "src/server/index.ts"],
      "env": {
        "DEFAULT_TENANT": "flutur",
        "NODE_NO_WARNINGS": "1"
      }
    }
  }
}
